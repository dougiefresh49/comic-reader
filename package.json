{
  "name": "comic-reader",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "next lint && tsc --noEmit",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "audio-downloader": "node scripts/audio-downloader.js",
    "video-download": "node scripts/video-download.js",
    "download-comic-images": "python3 scripts/download_comic_images.py",
    "get-context": "tsx --env-file=.env scripts/get-context.ts",
    "backfill-context": "tsx --env-file=.env scripts/backfill-context.ts",
    "generate-character-voice-descriptions": "tsx --env-file=.env scripts/generate-character-voice-descriptions.ts",
    "generate-voice-models": "tsx --env-file=.env scripts/generate-voice-models.ts",
    "clean-voice-descriptions": "tsx --env-file=.env scripts/clean-voice-descriptions.ts",
    "generate-audio": "tsx --env-file=.env scripts/generate-audio.ts",
    "sort-bubbles": "tsx --env-file=.env scripts/sort-bubbles.ts",
    "sort-bubbles-gemini": "tsx --env-file=.env scripts/sort-bubbles-gemini.ts",
    "convert-pages-to-webp": "tsx --env-file=.env scripts/convert-pages-to-webp.ts",
    "copy-to-public": "tsx --env-file=.env scripts/copy-to-public.ts",
    "generate-manifest": "tsx --env-file=.env scripts/generate-manifest.ts",
    "regenerate-timestamps": "tsx --env-file=.env scripts/regenerate-timestamps.ts",
    "generate-pages-metadata": "tsx --env-file=.env scripts/generate-pages-metadata.ts",
    "add-bubble-styles": "tsx --env-file=.env scripts/add-bubble-styles.ts",
    "repair-cues": "tsx --env-file=.env scripts/repair-cues.ts",
    "clip-audio-segments": "tsx scripts/clip-audio-segments.ts",
    "review-speakers": "tsx --env-file=.env scripts/review-speakers.ts",
    "review-new-characters": "tsx --env-file=.env scripts/review-new-characters.ts",
    "find-voice-sources": "tsx --env-file=.env scripts/find-voice-sources.ts",
    "manage-registry": "tsx --env-file=.env scripts/manage-registry.ts",
    "ingest": "tsx --env-file=.env scripts/ingest.ts",
    "scrape-pages": "tsx --env-file=.env scripts/scrape-pages.ts",
    "apply-fixes": "tsx --env-file=.env scripts/apply-fixes.ts",
    "ocr-flagged-bubbles": "tsx --env-file=.env scripts/ocr-flagged-bubbles.ts",
    "orch-fixes": "tsx --env-file=.env scripts/orch-fixes.ts",
    "motion-comic": "tsx --env-file=.env scripts/motion-comic.ts",
    "generate-episode": "tsx --env-file=.env scripts/generate-episode.ts",
    "migrate-to-db": "tsx --env-file=.env scripts/migrate-to-db.ts",
    "upload-to-storage": "tsx --env-file=.env scripts/upload-to-storage.ts"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.2.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@elevenlabs/elevenlabs-js": "^2.25.1",
    "@google/genai": "^1.30.0",
    "@supabase/supabase-js": "^2.105.0",
    "@t3-oss/env-nextjs": "^0.12.0",
    "fs-extra": "^11.3.2",
    "glob": "^13.0.0",
    "next": "15.2.6",
    "p-limit": "^7.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "youtube-dl-exec": "^3.0.26",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.3",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "supabase": "^2.95.5",
    "tailwindcss": "^4.0.15",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "pnpm@10.33.2"
}
